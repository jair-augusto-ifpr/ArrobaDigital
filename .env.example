# Copie para .env e preencha (mesma pasta que main.py).
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO
API_KEY_IA=api_key_ia

# Modelo padrão (texto + visão). GPT-4o mini = melhor custo/benefício para
# tarefas de auxílio (laudo, raça provável, ECC, observações). Vision solido,
# suporta role=system nativo (sem hacks do Gemma), rate-limit confortavel.
# Preço (abril/2026): ~US$ 0.15/M input, US$ 0.60/M output.
IA_MODEL=openai/gpt-4o-mini

# Alternativas já validadas no OpenRouter (todas multimodais):
#   openai/gpt-4o-mini                 <- padrão, equilíbrio bom
#   openai/gpt-4o                      <- vision superior, ~15x mais caro
#   anthropic/claude-3.5-haiku         <- alternativa boa, vision decente
#   anthropic/claude-3.5-sonnet        <- vision excelente, caro
#   google/gemini-2.5-flash            <- custo muito baixo, vision ótima
#   google/gemma-4-26b-a4b-it:free     <- FREE (rate-limit agressivo, 50/dia)

# Opcional: modelo separado so para tarefas com imagem (default = IA_MODEL).
# IA_VISION_MODEL=openai/gpt-4o
